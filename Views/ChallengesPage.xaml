<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutManagerNoam.Views.ChallengesPage"
             Title="Challenges">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="My Challenges"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <CollectionView x:Name="ChallengesCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                Padding="15"
                                Margin="0,5">
                            <VerticalStackLayout Spacing="10">

                                <Label Text="{Binding Title}"
                                       FontSize="20"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Category, StringFormat='Category: {0}'}" />
                                <Label Text="{Binding Difficulty, StringFormat='Difficulty: {0}'}" />
                                <Label Text="{Binding RewardAmount, StringFormat='Reward: ₪{0}'}" />

                                <Button Text="CLAIM REWARD"
                                        Clicked="ClaimReward_Clicked">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsCompleted}"
                                                     Value="False">
                                            <Setter Property="Text" Value="PENDING" />
                                            <Setter Property="BackgroundColor" Value="Red" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>

                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsClaimed}"
                                                     Value="True">
                                            <Setter Property="Text" Value="CLAIMED" />
                                            <Setter Property="BackgroundColor" Value="Gray" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>