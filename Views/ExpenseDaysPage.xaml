<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutManagerNoam.Views.ExpenseDaysPage"
             Title="Expense Days">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Expense Days"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <CollectionView x:Name="DaysCollection"
                            SelectionMode="Single"
                            SelectionChanged="DaysCollection_SelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                Padding="15"
                                Margin="0,5">
                            <Label Text="{Binding StringFormat='{}{0:dd/MM/yyyy}'}"
                                   FontSize="18" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>