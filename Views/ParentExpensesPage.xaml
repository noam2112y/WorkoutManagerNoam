<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutManagerNoam.Views.ParentExpensesPage"
             Title="All Expenses">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="All Child Expenses"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <CollectionView x:Name="ExpensesCollection">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                Padding="15"
                                Margin="0,5">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Category, StringFormat='Category: {0}'}" />
                                <Label Text="{Binding Amount, StringFormat='Amount: ₪{0}'}" />
                                <Label Text="{Binding Date, StringFormat='Date: {0:dd/MM/yyyy HH:mm}'}" />
                                <Label Text="{Binding IsSOS, StringFormat='SOS: {0}'}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>