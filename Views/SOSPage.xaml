<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutManagerNoam.Views.SOSPage"
             Title="SOS">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label Text="SOS Emergency"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Emergency only. Max ₪200"
                   HorizontalOptions="Center" />

            <Entry x:Name="SOSAmountEntry"
                   Placeholder="Enter amount"
                   Keyboard="Numeric" />

            <Button Text="Take SOS Money"
                    Clicked="TakeSOSMoney_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>