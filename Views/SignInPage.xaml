<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WorkoutManagerNoam.Views.SignInPage"
             xmlns:vm="clr-namespace:WorkoutManagerNoam.ViewModels"
             x:DataType="vm:SignInViewModel"
             NavigationPage.HasBackButton="False"
             Title="SignInPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="LightCyan"/>
            <GradientStop Offset="0.5" Color="#3a7bd5"/>
            <GradientStop Offset="1.0" Color="Purple"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

        <Label FontAttributes="Bold"
               FontSize="25"
               Text="כניסה"
               TextColor="Black" />

        <Border Padding="10"
                Stroke="Black"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">
            <Entry Text="{Binding UserName}"
                   Keyboard="Email"
                   FontSize="18"
                   Placeholder="Email"
                   PlaceholderColor="Black"
                   TextColor="Black" />
        </Border>
    
        <Border Stroke="Black"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">
            <Grid Padding="10"
                  ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">

                <Entry Text="{Binding UserPassword}"
                       BackgroundColor="Transparent"
                       FontSize="18"
                       IsPassword="{Binding EntryAsPassword}"
                       Placeholder="סיסמה"
                       PlaceholderColor="Black"
                       TextColor="Black"
                       VerticalOptions="Center" />

                <Button Margin="5,0,0,0"
                        Padding="0"
                        BackgroundColor="Transparent"
                        FontSize="24"
                        HorizontalOptions="End"
                        FontFamily="MaterialIcons"
                        Text="{Binding PassIcon}"
                        TextColor="Black"
                        VerticalOptions="Center"
                        Command="{Binding ShowPasswordCommand}" />
            </Grid>
        </Border>

        <Button CornerRadius="8"
                FontSize="18"
                HeightRequest="50"
                Text="חיבור"
                TextColor="Black"
                IsEnabled="{Binding IsSignInButtonEnabled}"
                Command="{Binding SignInCommand}"/>

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
            <Label Text="אין לך משתמש?" TextColor="Black" />
            <Button Text="SignUp"
                    BackgroundColor="Transparent"
                    TextColor="Black"
                    Command="{Binding NavigateToSignUpCommand}" />
        </HorizontalStackLayout>
        <HorizontalStackLayout 
            Spacing="10"
            VerticalOptions="Center">
            <CheckBox IsChecked="{Binding RememberMe}" Color="White"/>
            <Label Text="Remember me" TextColor="Black" FontSize="16"/>
        </HorizontalStackLayout>
        <Label FontSize="28"
               HorizontalTextAlignment="Center"
               IsVisible="{Binding SingInMessageVisible}"
               Text="{Binding LoginMessage}"
               TextColor="Red" />

    </VerticalStackLayout>
</ContentPage>
