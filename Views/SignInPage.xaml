<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="WorkoutManagerNoam.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WorkoutManagerNoam.ViewModels"
    x:DataType="vm:SignInViewModel"
    Title="Sign In"
    BackgroundColor="#F4F7FB"
    NavigationPage.HasBackButton="False">

    <ScrollView>
        <Grid
            Padding="28"
            RowDefinitions="*,Auto,*">

            <Border
                Grid.Row="1"
                Padding="26"
                BackgroundColor="White"
                Stroke="#D8DEE9"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22"
                MaximumWidthRequest="430"
                HorizontalOptions="Center">

                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.25" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Workout Manager"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#16233A"
                            HorizontalTextAlignment="Center" />

                        <Label
                            Text="Sign in to continue"
                            FontSize="15"
                            TextColor="#6B7280"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <BoxView
                        HeightRequest="1"
                        BackgroundColor="#E5E7EB"
                        Margin="0,6,0,4" />

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Email"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#374151" />

                        <Border
                            Padding="14,4"
                            BackgroundColor="#F9FAFB"
                            Stroke="#CBD5E1"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">

                            <Entry
                                Text="{Binding FirstName}"
                                Keyboard="Email"
                                Placeholder="Enter your email"
                                PlaceholderColor="#9CA3AF"
                                TextColor="#111827"
                                FontSize="16"
                                BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Password"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#374151" />

                        <Border
                            BackgroundColor="#F9FAFB"
                            Stroke="#CBD5E1"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">

                            <Grid
                                Padding="14,4"
                                ColumnDefinitions="*,Auto">

                                <Entry
                                    Grid.Column="0"
                                    Text="{Binding UserPassword}"
                                    IsPassword="{Binding EntryAsPassword}"
                                    Placeholder="Enter your password"
                                    PlaceholderColor="#9CA3AF"
                                    TextColor="#111827"
                                    FontSize="16"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center" />

                                <Button
                                    Grid.Column="1"
                                    Text="{Binding PassIcon}"
                                    Command="{Binding ShowPasswordCommand}"
                                    FontFamily="MaterialIcons"
                                    FontSize="23"
                                    BackgroundColor="Transparent"
                                    TextColor="#374151"
                                    Padding="8,0"
                                    WidthRequest="46"
                                    HeightRequest="42"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <HorizontalStackLayout
                        Spacing="8"
                        VerticalOptions="Center">

                        <CheckBox
                            IsChecked="{Binding RememberMeChecked}"
                            Color="#1D4ED8"
                            VerticalOptions="Center" />

                        <Label
                            Text="Remember me"
                            FontSize="15"
                            TextColor="#374151"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label
                        Text="{Binding LoginMessage}"
                        IsVisible="{Binding SingInMessageVisible}"
                        TextColor="#DC2626"
                        FontSize="14"
                        HorizontalTextAlignment="Center" />

                    <Button
                        Text="Sign In"
                        Command="{Binding SignInCommand}"
                        IsEnabled="{Binding IsSignInButtonEnabled}"
                        HeightRequest="52"
                        CornerRadius="14"
                        BackgroundColor="#1D4ED8"
                        TextColor="White"
                        FontSize="17"
                        FontAttributes="Bold" />

                    <HorizontalStackLayout
                        HorizontalOptions="Center"
                        Spacing="6">

                        <Label
                            Text="Don't have an account?"
                            TextColor="#6B7280"
                            FontSize="14"
                            VerticalOptions="Center" />

                        <Button
                            Text="Sign Up"
                            Command="{Binding NavigateToSignUpCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#1D4ED8"
                            FontAttributes="Bold"
                            Padding="0"
                            FontSize="14" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>