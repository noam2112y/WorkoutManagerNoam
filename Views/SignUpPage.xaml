<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutManagerNoam.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sign Up"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="18">

            <Label
                FontAttributes="Bold"
                FontSize="30"
                HorizontalOptions="Center"
                Text="Create Account" />

            <Entry Placeholder="First Name" Text="{Binding FirstName}" />

            <Entry Placeholder="Last Name" Text="{Binding LastName}" />

            <Entry
                Keyboard="Email"
                Placeholder="Email"
                Text="{Binding UserEmail}" />

            <Grid ColumnDefinitions="*,Auto">
                <Entry
                    IsPassword="{Binding EntryAsPassword}"
                    Placeholder="Password"
                    Text="{Binding UserPassword}" />

                <Button
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Command="{Binding TogglePasswordCommand}"
                    FontFamily="FaSolid"
                    Text="{Binding PasswordIconCode}"
                    WidthRequest="50" />
            </Grid>

            <Entry
                Keyboard="Telephone"
                Placeholder="Mobile"
                Text="{Binding Mobile}" />

            <HorizontalStackLayout Spacing="12">
                <Label Text="Parent Account" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsParent}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Button Command="{Binding SignUpCommand}" Text="Sign Up" />

            <Button
                BackgroundColor="Transparent"
                Command="{Binding BackToSignInCommand}"
                Text="Back to Sign In"
                TextColor="Blue" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>